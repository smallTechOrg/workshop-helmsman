# Workshop Helmsman — environment template
#
# No secrets required. All state is local SQLite at ./data/helmsman.db
# (created on first boot).
#
# Copy this file to `.env` only if you want to override defaults; nothing
# inside .env is required for Phase 1.

# --- Server ---
# BIND_HOST=0.0.0.0
# BIND_PORT=8001

# --- Data ---
# DATABASE_URL=sqlite:///./data/helmsman.db

# --- Workshop defaults ---
# DEFAULT_WORKSHOP_TTL_HOURS=8
